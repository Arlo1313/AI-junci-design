<view style="min-height:100vh;background:#f8f5f2;padding:0 24rpx;">
  <view class="nav-header">
    <text class="nav-title">我的定制车</text>
  </view>

  <view wx:if="{{items.length===0}}" style="text-align:center;padding:120rpx 60rpx;color:#a28d7c;">
    <text style="font-size:32rpx;display:block;margin-bottom:12rpx;">🛒 定制车空空如也</text>
    <text style="font-size:26rpx;display:block;margin-bottom:40rpx;">去「AI设计」添加你的专属钧瓷吧</text>
    <button class="btn" style="width:300rpx;margin:0 auto;background:transparent;color:#9f2e1c;border:2rpx solid #9f2e1c;" bindtap="goAI">去AI设计</button>
  </view>

  <view wx:if="{{items.length>0}}">
    <view wx:for="{{items}}" wx:key="id" style="display:flex;gap:24rpx;background:#fff;border-radius:20rpx;padding:24rpx;margin-bottom:24rpx;align-items:center;">
      <image src="{{item.image}}" mode="aspectFill" style="width:120rpx;height:120rpx;border-radius:16rpx;background:#d9c8ba;"/>
      <view style="flex:1;">
        <text style="font-weight:600;font-size:28rpx;display:block;">{{item.name}}</text>
        <text style="color:#7a6858;font-size:24rpx;display:block;margin-top:4rpx;">{{item.shape}} · {{item.glaze}}</text>
      </view>
      <text style="color:#b53b28;font-weight:650;">¥{{item.price}}</text>
    </view>

    <view style="display:flex;justify-content:space-between;padding:24rpx 0;">
      <text>共 {{items.length}} 件</text>
      <text>合计: <text style="color:#b53b28;font-weight:700;">¥{{total}}</text></text>
    </view>
    <button class="btn" bindtap="submit">提交订单 · 等待开窑</button>
  </view>

  <view class="bottom-space"></view>
</view>