<view style="min-height:100vh;background:#f8f5f2;">
  <view class="nav-header">
    <text class="nav-title">AI钧瓷文创设计</text>
  </view>

  <view class="search-bar">
    <text style="color:#a28d7c;">搜索你喜欢的钧瓷...</text>
  </view>

  <view class="card" style="background:#b53b28;color:#fff;margin:0 24rpx 24rpx;padding:24rpx;" bindtap="goAI">
    <text style="font-weight:600;font-size:36rpx;display:block;">AI设计 · 开窑有喜</text>
    <text style="opacity:0.9;font-size:26rpx;margin-top:8rpx;display:block;">用文字生成你的专属钧瓷 →</text>
  </view>

  <view style="display:flex;justify-content:space-around;margin-bottom:32rpx;padding:0 24rpx;">
    <view style="text-align:center;" bindtap="goAI">
      <view style="background:rgba(159,46,28,0.1);width:100rpx;height:100rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12rpx;color:#9f2e1c;font-size:40rpx;">✨</view>
      <text style="font-size:24rpx;">AI设计</text>
    </view>
    <view style="text-align:center;" bindtap="showTip" data-msg="盲盒商城即将上线">
      <view style="background:rgba(159,46,28,0.1);width:100rpx;height:100rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12rpx;color:#9f2e1c;font-size:40rpx;">🎁</view>
      <text style="font-size:24rpx;">盲盒</text>
    </view>
    <view style="text-align:center;" bindtap="showTip" data-msg="大师联名系列">
      <view style="background:rgba(159,46,28,0.1);width:100rpx;height:100rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12rpx;color:#9f2e1c;font-size:40rpx;">🏺</view>
      <text style="font-size:24rpx;">大师联名</text>
    </view>
    <view style="text-align:center;" bindtap="showTip" data-msg="共创社区即将开放">
      <view style="background:rgba(159,46,28,0.1);width:100rpx;height:100rpx;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12rpx;color:#9f2e1c;font-size:40rpx;">✏️</view>
      <text style="font-size:24rpx;">共创</text>
    </view>
  </view>

  <view style="padding:0 24rpx;margin-bottom:16rpx;">
    <text style="font-weight:650;font-size:32rpx;">🔥 热门盲盒</text>
  </view>

  <view class="product-grid">
    <view class="product-item" bindtap="showTip" data-msg="生肖·灵驹">
      <image class="product-img" src="/images/prod_horse.jpg" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-title">生肖·灵驹</text>
        <text class="product-price">¥39</text>
      </view>
    </view>
    <view class="product-item" bindtap="showTip" data-msg="天青茶盏">
      <image class="product-img" src="/images/prod_cup.jpg" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-title">天青茶盏</text>
        <text class="product-price">¥89</text>
      </view>
    </view>
    <view class="product-item" bindtap="showTip" data-msg="星空窑变">
      <image class="product-img" src="/images/prod_star.jpg" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-title">星空窑变</text>
        <text class="product-price">¥299</text>
      </view>
    </view>
    <view class="product-item" bindtap="showTip" data-msg="瑞彩·祥瑞">
      <image class="product-img" src="/images/prod_pendant.jpg" mode="aspectFill"/>
      <view class="product-info">
        <text class="product-title">瑞彩·祥瑞</text>
        <text class="product-price">¥79</text>
      </view>
    </view>
  </view>

  <view class="bottom-space"></view>
</view>