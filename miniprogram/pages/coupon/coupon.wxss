.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 10rpx;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.coupon-card {
  background: #fff;
  border-radius: 16rpx;
  display: flex;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.coupon-left {
  width: 200rpx;
  background: #c44a34;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.amount {
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
}

.condition {
  color: rgba(255,255,255,0.8);
  font-size: 22rpx;
  margin-top: 8rpx;
}

.coupon-right {
  flex: 1;
  padding: 24rpx 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
}

.name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.valid {
  font-size: 24rpx;
  color: #999;
}

.tag {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.tag.active {
  background: #fff2f0;
  color: #c44a34;
}

.tag.used {
  background: #f0f0f0;
  color: #999;
}