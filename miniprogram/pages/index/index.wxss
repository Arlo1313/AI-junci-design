/* 首页样式 */

/* 盲盒容器 */
.blind-box-container {
  margin: 0 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

/* 盲盒标题栏 */
.blind-box-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.header-left {
  display: flex;
  align-items: center;
}

.header-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 650;
  color: #333;
}

.header-right {
  display: flex;
  align-items: center;
}

.header-more {
  font-size: 26rpx;
  color: #999;
  margin-right: 8rpx;
}

.header-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 系列分类导航 */
.series-nav {
  display: flex;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  margin-right: 16rpx;
  transition: all 0.3s ease;
}

.nav-item.active {
  background: rgba(181,59,40,0.1);
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-text {
  font-size: 24rpx;
  color: #666;
}

.nav-item.active .nav-text {
  color: #b53b28;
  font-weight: 600;
}

/* 系列内容区域 */
.series-content {
  padding: 24rpx;
}

/* 封面展示 */
.series-cover {
  position: relative;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.cover-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 24rpx;
}

.cover-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

/* 十二生肖网格 */
.zodiac-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.zodiac-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.zodiac-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.zodiac-name {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
}

/* 系列介绍 */
.series-intro {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.intro-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.intro-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.intro-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #b53b28;
}

/* 小首饰系列网格 */
.jewelry-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.jewelry-item {
  display: flex;
  flex-direction: column;
  background: #f8f8f8;
  border-radius: 12rpx;
  overflow: hidden;
}

.jewelry-img {
  width: 100%;
  height: 200rpx;
}

.jewelry-info {
  padding: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.jewelry-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.jewelry-price {
  font-size: 28rpx;
  color: #b53b28;
  font-weight: 600;
}

/* 杯子系列网格 */
.cup-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.cup-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.cup-img {
  width: 100%;
  height: 160rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.cup-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.cup-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.cup-price {
  font-size: 26rpx;
  color: #b53b28;
  font-weight: 600;
}

/* 底部购买按钮 */
.blind-box-footer {
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fafafa;
}

.buy-btn {
  width: 100%;
  background: linear-gradient(135deg, #b53b28 0%, #9f2e1c 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx;
  border-radius: 40rpx;
  border: none;
}

/* 底部空间 */
.bottom-space {
  height: 40rpx;
}
