page {
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  background: #f8f5f2;
  color: #3a2c22;
}

.nav-header {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
}

.nav-title {
  font-size: 40rpx;
  font-weight: 700;
  flex: 1;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 0 24rpx 24rpx;
}

.btn {
  background: #9f2e1c;
  color: #fff;
  border: none;
  padding: 28rpx 0;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.search-bar {
  background: #f3eeea;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  margin: 8rpx 24rpx 20rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 24rpx;
}

.product-item {
  width: calc(50% - 10rpx);
  background: #fefcf9;
  border-radius: 24rpx;
  overflow: hidden;
  border: 2rpx solid #f0e8e0;
}

.product-img {
  width: 100%;
  height: 260rpx;
  background: linear-gradient(145deg, #d4c4b5, #e8d9cc);
}

.product-info {
  padding: 18rpx 20rpx;
}

.product-title {
  font-size: 28rpx;
  font-weight: 600;
}

.product-price {
  color: #b53b28;
  font-weight: 650;
  font-size: 30rpx;
}

.bottom-space {
  height: 40rpx;
}